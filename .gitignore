# ===================================================================
# PENANA-NEXT Monorepo - The Ultimate .gitignore
# This is the single source of truth for the entire project.
# ===================================================================

# --- Universal / Global Rules ---

# Dependencies & Lockfiles (Applies to all workspaces)
# The trailing slash ensures we only match directories
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Environment Variables (CRITICAL FOR SECURITY)
# Ignore all .env files but allow example files to be committed.
.env*
!.env.example

# Log files
# Catches all log files from any tool.
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# --- Workspace-Specific Build Outputs ---

# Frontend (Next.js)
# These are generated when you build or run the frontend app.
/frontend/.next/
/frontend/out/
/frontend/build/

# Backend (NestJS)
# This is the compiled JavaScript output for the backend.
/backend/dist/
/backend/build/

# TypeScript Build Info
# Caching file for faster subsequent compilations.
*.tsbuildinfo

# --- Testing ---

# Test coverage reports
/coverage/
backend/coverage/
/.nyc_output/

# --- OS & System Files ---

# macOS
.DS_Store

# Windows
Thumbs.db

# --- IDEs & Editors ---

# General
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# JetBrains (WebStorm, IntelliJ)
/.idea/

# VSCode (A common pattern to share some settings but not user-specific ones)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- Miscellaneous ---

# Vercel deployment files
.vercel/

# Temporary files
.temp/
.tmp/

# Runtime data from server processes
pids/
*.pid
*.seed
*.pid.lock

# Security certificates
*.pem

# Node.js diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# This is generated by Next.js, safe to ignore
next-env.d.ts

/database-dev/
.env.local
.env
.env.download
tools/migration/log.txt
tools/migration/test.ts
/TwistedTales-GAS/
/img/反轉童話.psd
/img/頭像.psd

# Secret config — generated by CI from GitHub Secrets
config.js

# Claude Code local settings
.claude/settings.local.json!config.js
